# Harbor Voice Server Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development
VOICE_SERVER_HOST=your-voice-server.railway.app  # Your Railway deployment URL (no protocol)

# Supabase (same as main Harbor app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini (voice conversation LLM)
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Anthropic (crisis analysis via Claude Sonnet - only called when tripwire fires)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Twilio (same as main Harbor app - used for crisis SMS alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15415394890
