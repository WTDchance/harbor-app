# ========================================
# HARBOR - AI RECEPTIONIST FOR THERAPISTS
# ========================================
# Copy this file to .env.local and fill in your values

# DATABASE (Supabase PostgreSQL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here

# VOICE AI (Vapi.ai)
# Get your API key at https://dashboard.vapi.ai
# The webhook secret protects the /api/vapi/webhook endpoint
VAPI_API_KEY=your_vapi_api_key_here
VAPI_WEBHOOK_SECRET=your_webhook_secret_here
# BYOM: Add your Gemini key in Vapi dashboard â Provider Keys â Google
# This lets Vapi use Gemini 2.0 Flash at your own API cost ($0.005/min vs their markup)

# SMS & VOICE (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
SMS_ENABLED=false

# AI (Anthropic Claude â used for SMS responses, call summaries, crisis detection)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PAYMENTS (Stripe)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# APP CONFIG
NEXT_PUBLIC_APP_NAME=Harbor
NEXT_PUBLIC_APP_URL=https://harborreceptionist.com
NODE_ENV=production

# SMS APPOINTMENT REMINDERS
REMINDER_SECRET=your_secret_cron_token_here

# EMAIL (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Chance@harborreceptionist.com
RESEND_CHANCE_EMAIL=Chance@harborreceptionist.com
RESEND_SALES_EMAIL=Sales@harborreceptionist.com
RESEND_SUPPORT_EMAIL=Support@harborreceptionist.com

# ========================================
# VAPI SETUP CHECKLIST
# ========================================
# 1. Create Vapi account at vapi.ai
# 2. In Vapi Dashboard â Phone Numbers: import your Twilio number
# 3. In Vapi Dashboard â Provider Keys: add your Google API key (for Gemini BYOM)
# 4. Set the server URL to: https://harborreceptionist.com/api/vapi/webhook?secret=YOUR_SECRET
# 5. The webhook handles assistant-request dynamically â no need to create assistants in Vapi dashboard
# 6. Each inbound call auto-resolves the practice by phone number and builds a custom assistant
