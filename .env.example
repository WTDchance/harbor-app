# ========================================
# THERALINK - AI RECEPTIONIST FOR THERAPISTS
# ========================================
# Copy this file to .env.local and fill in your values

# DATABASE (Supabase PostgreSQL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here

# VOICE AI (Vapi.ai - for phone call handling)
VAPI_API_KEY=your_vapi_api_key_here
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# SMS & VOICE (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_WEBHOOK_URL=https://your-domain.com/api/sms/inbound

# AI CONVERSATION (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PAYMENTS (Stripe)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# APP CONFIG
NEXT_PUBLIC_APP_NAME=TheraLink
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# SMS APPOINTMENT REMINDERS
REMINDER_SECRET=your_secret_cron_token_here
NEXT_PUBLIC_APP_URL=https://harbor-app-production.up.railway.app
# Cron URL: POST https://harbor-app-production.up.railway.app/api/reminders/send
# Header:   x-reminder-secret: <REMINDER_SECRET>
# Twilio inbound SMS webhook: https://harbor-app-production.up.railway.app/api/twilio/sms-webhook

# EMAIL (Resend - transactional email)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Chance@harborreceptionist.com
RESEND_CHANCE_EMAIL=Chance@harborreceptionist.com
RESEND_SALES_EMAIL=Sales@harborreceptionist.com
RESEND_SUPPORT_EMAIL=Support@harborreceptionist.com
