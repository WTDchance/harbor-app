# ========================================
# HARBOR - AI RECEPTIONIST FOR THERAPISTS
# ========================================
# Copy this file to .env.local and fill in your values

# DATABASE (Supabase PostgreSQL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here

# VOICE AI (Vapi.ai)
# Get your API key at https://dashboard.vapi.ai
# The webhook secret protects the /api/vapi/webhook endpoint
VAPI_API_KEY=your_vapi_api_key_here
VAPI_WEBHOOK_SECRET=your_webhook_secret_here
# LLM: Uses Vapi built-in GPT-4o-mini (no external API key needed)
# Voice: Uses Vapi built-in ElevenLabs Rachel (no separate key needed)

# SMS & VOICE (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
SMS_ENABLED=false

# AI (Anthropic Claude Ã¢ÂÂ used for SMS responses, call summaries, crisis detection)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PAYMENTS (Stripe)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# APP CONFIG
NEXT_PUBLIC_APP_NAME=Harbor
NEXT_PUBLIC_APP_URL=https://harborreceptionist.com
NODE_ENV=production

# SMS APPOINTMENT REMINDERS
REMINDER_SECRET=your_secret_cron_token_here

# ========================================
# SIGNALWIRE SMS (Wave 50 — appointment reminder pipeline)
# ========================================
# SignalWire dashboard: https://signalwire.com — copy from project page.
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_API_TOKEN=
SIGNALWIRE_FROM_NUMBER=+15551234567
# LaML "Signing Key" (PSK_…), used for inbound webhook signature
# verification. Different from the project token (PT_…) used for REST.
SIGNALWIRE_WEBHOOK_SIGNING_KEY=
# Master kill-switch for live SMS sends. Defaults to false; the wrapper
# logs every send with status=dry_run_skipped until this is flipped to
# the literal string "true" (after the SignalWire BAA + A2P 10DLC
# registration is approved). Inbound webhook + cron run end-to-end in
# dry-run today.
SMS_LIVE_SEND=false

# EMAIL (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Chance@harborreceptionist.com
RESEND_CHANCE_EMAIL=Chance@harborreceptionist.com
RESEND_SALES_EMAIL=Sales@harborreceptionist.com
RESEND_SUPPORT_EMAIL=Support@harborreceptionist.com

# ========================================
# VAPI SETUP CHECKLIST
# ========================================
# 1. Create Vapi account at vapi.ai
# 2. In Vapi Dashboard Ã¢ÂÂ Phone Numbers: import your Twilio number
# 3. No provider keys needed â LLM and voice use Vapi built-in
# 4. Set the server URL to: https://harborreceptionist.com/api/vapi/webhook?secret=YOUR_SECRET
# 5. The webhook handles assistant-request dynamically Ã¢ÂÂ no need to create assistants in Vapi dashboard
# 6. Each inbound call auto-resolves the practice by phone number and builds a custom assistant

# deploy touch: 2026-04-21 crisis-ui

# W51 — Reception + Verify pricing tier
STRIPE_PRICE_RECEPTION_WITH_VERIFY_MONTHLY=
