{
  "name": "harbor-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ehr": "dotenv -e .env.ehr -- next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "npx supabase gen types typescript --project-id YOUR_PROJECT_ID > types/database.ts",
    "ehr:bootstrap": "node --env-file=.env.ehr scripts/enable-extensions.mjs && node --env-file=.env.ehr scripts/bootstrap-ehr-db.mjs",
    "ehr:inspect": "node --env-file=.env.ehr scripts/inspect-ehr-db.mjs",
    "ehr:seed": "node --env-file=.env.ehr scripts/seed-ehr-test-data.mjs",
    "drizzle:introspect": "drizzle-kit introspect:pg"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-bedrock-runtime": "^3.654.0",
    "@aws-sdk/client-chime-sdk-meetings": "^3.654.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.654.0",
    "@aws-sdk/client-s3": "^3.654.0",
    "@aws-sdk/client-ses": "^3.654.0",
    "@aws-sdk/client-transcribe": "^3.654.0",
    "@aws-sdk/lib-storage": "^3.654.0",
    "@aws-sdk/s3-request-presigner": "^3.654.0",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.38.0",
    "@tailwindcss/typography": "^0.5.10",
    "@types/qrcode": "^1.5.5",
    "amazon-chime-sdk-js": "^3.30.0",
    "aws-jwt-verify": "^5.1.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "drizzle-orm": "^0.36.0",
    "gray-matter": "^4.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.292.0",
    "marked": "^12.0.0",
    "next": "^14.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.0",
    "posthog-js": "^1.200.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "stripe": "^14.0.0",
    "tailwindcss": "^3.3.0",
    "tsdav": "^2.0.0",
    "twilio": "^4.10.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.28.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.2.0"
  }
}
