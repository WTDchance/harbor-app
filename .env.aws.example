# ----- App runtime (staging) -----
NODE_ENV=staging
AWS_REGION=us-east-1
APP_URL=https://lab.harboroffice.ai

# ----- Database -----
# Populated by ECS task definition from SSM at runtime (except for local dev).
PGHOST=harbor-staging-pg.xxxxxxxx.us-east-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=harbor
PGUSER=harbor_admin
PGPASSWORD=__pull_from_ssm__
PGSSLMODE=require

# ----- Auth (Cognito) -----
COGNITO_USER_POOL_ID=us-east-1_XXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXX

# ----- Bedrock (replaces ANTHROPIC_API_KEY) -----
BEDROCK_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-v1:0
BEDROCK_SONNET_MODEL=us.anthropic.claude-sonnet-4-6-v1:0

# ----- Email (SES replaces Resend) -----
SES_FROM_ADDRESS=ellie@harboroffice.ai
SES_CONFIGURATION_SET=harbor-staging-config

# ----- Storage -----
S3_UPLOADS_BUCKET=harbor-staging-uploads-417242953135

# ----- Voice provider -----
# Start on Retell for cost; keep Vapi env vars around until cutover is tested.
VOICE_PROVIDER=retell
RETELL_API_KEY=__pull_from_ssm__

# ----- Telephony -----
# SignalWire for SIP in staging.
SIGNALWIRE_PROJECT_ID=__pull_from_ssm__
SIGNALWIRE_API_TOKEN=__pull_from_ssm__
SIGNALWIRE_SPACE=__pull_from_ssm__

# ----- Billing -----
STRIPE_SECRET_KEY=__pull_from_ssm__
STRIPE_WEBHOOK_SECRET=__pull_from_ssm__
STRIPE_PRICE_ID_REGULAR=price_1TOPJZFUPyY9mpX1Otq4bQhX
STRIPE_PRICE_ID_FOUNDING=price_1TOPJZFUPyY9mpX1R01TcOQv

# ----- Insurance -----
STEDI_API_KEY=__pull_from_ssm__

# ----- Admin -----
CRON_SECRET=__pull_from_ssm__
